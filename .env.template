# ============================================================
# Local Virtual Service — YouTube 转录 Worker
# 部署在家庭网络虚拟机上，通过公网直连服务器 Redis / PostgreSQL
# ============================================================

# ===== 数据库 =====
DB_HOST=43.99.37.76
DB_PORT=5432
DB_NAME=guanhe_database
DB_USER=postgres
DB_PASSWORD=<与服务器 .env 一致>

# ===== Redis / Celery Broker =====
REDIS_URL=redis://:<URL编码后的Redis密码>@43.99.37.76:6379/0

# ===== YouTube Data API v3（RSS 不可用时的回退方案）=====
# 在 https://console.cloud.google.com/ 启用 YouTube Data API v3 后创建 API Key
# YOUTUBE_DATA_API_KEY=

# ===== 阿里云 OSS（Fun-ASR 需要通过 OSS URL 拉取音频）=====
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET_NAME=rc-audio-files
# OSS_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
# OSS_ASR_PUBLIC_READ=true

# ===== 阿里云 DashScope（Fun-ASR 语音识别）=====
# DASHSCOPE_API_KEY=

# ===== yt-dlp 认证（可选，解决 YouTube 反爬）=====
# YOUTUBE_COOKIES_FILE=/path/to/cookies.txt
# YOUTUBE_PO_TOKEN=
# YOUTUBE_VISITOR_DATA=

# ===== 网络代理（可选）=====
# YOUTUBE_PROXY=http://127.0.0.1:7890

# ===== 日志 =====
LOG_DIR=./logs
LOG_LEVEL=INFO

# ============================================================
# Local Virtual Service — YouTube 转录 Worker — 配置模板
#
# 使用方法:
#   cp .env.template .env
#   nano .env   # 填入下方带 <...> 标记的必填项
# ============================================================


# ============================================================
# 一、基础设施连接（必填）
# ============================================================

# ----- 数据库 -----
DB_HOST=<your-server-ip>
DB_PORT=5432
DB_NAME=<your-db-name>
DB_USER=postgres
DB_PASSWORD=<your-db-password>

# ----- Redis / Celery Broker -----
# 密码里的特殊字符需按 URL 编码: , → %2C   + → %2B   @ → %40   ! → %21
REDIS_URL=redis://:<URL编码后的Redis密码>@<your-server-ip>:6379/0
# 本地测试：连本机 Redis
# REDIS_URL=redis://127.0.0.1:6379/0

# ----- YouTube Data API v3（RSS 不可用时的回退方案）-----
# 在 https://console.cloud.google.com/ 启用 YouTube Data API v3 后创建 API Key
# YOUTUBE_DATA_API_KEY=

# ----- 阿里云 OSS（Fun-ASR 需要通过 OSS URL 拉取音频）-----
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET_NAME=
# OSS_ENDPOINT=oss-cn-hongkong.aliyuncs.com
# OSS_ASR_PUBLIC_READ=false
# 签名 URL 有效期（秒），默认 172800 = 48h。Fun-ASR 异步任务可能排队数小时，不建议小于 12h
OSS_SIGNED_URL_TTL_SECONDS=172800

# ----- 阿里云 DashScope（Fun-ASR 语音识别）-----
# DASHSCOPE_API_KEY=


# ============================================================
# 二、yt-dlp 认证 / 代理（可选，解决 YouTube 反爬）
# ============================================================

# Cookies 文件（强烈建议配置，能大幅提升 YouTube 配额）
# 浏览器装 "Get cookies.txt LOCALLY" 插件 → 登录 YouTube → 导出 → 上传到此路径
# YOUTUBE_COOKIES_FILE=/path/to/cookies.txt

# PO Token（Proof-of-Origin）: 支持两种格式，代码自动识别
#   1) 老格式(向后兼容): 单个裸 token —— 代码会自动扩展到 gvs / player / subs 各 context
#        YOUTUBE_PO_TOKEN=MnRh…
#   2) 新格式(推荐): 按 yt-dlp 文档的 CLIENT.CONTEXT+TOKEN，可多个逗号分隔
#        YOUTUBE_PO_TOKEN=web.gvs+XXX,web.subs+YYY,web.player=ZZZ
#   context 含义: gvs=视频服务器 / player=Innertube / subs=字幕
# YOUTUBE_PO_TOKEN=
# YOUTUBE_VISITOR_DATA=

# 网络代理（可选，作用于 yt-dlp / RSS / Data API v3）
# 注意：此代理不会被传给 youtube-transcript-api（那条链路用下面的 Webshare 配置）。
# YOUTUBE_PROXY=http://127.0.0.1:7890

# ----- Webshare 住宅代理（仅作用于 youtube-transcript-api）-----
# 用途：当家庭/服务器 IP 被 YouTube 在 /api/timedtext endpoint 上封禁时，
#       让 youtube-transcript-api 走旋转住宅代理重新拿到字幕。
# 范围：仅这一条链路被代理。yt-dlp 的音频下载 / OSS 上传 / DashScope ASR
#       全部继续走本机直连，所以代理流量极小（典型 5–50 KB/视频）。
# 计费：Webshare Rotating Residential 按代理通道总字节计费 ($1.40~$3.50/GB)。
#       因此 NEVER 把账号写到 HTTPS_PROXY / HTTP_PROXY 里——那会让 OSS 上传也走代理，
#       一个长视频就能烧掉几美元。
# 启用方法：在 https://dashboard.webshare.io/proxy/settings 创建 Rotating Residential
#           套餐后填下面两行；不填 = 直连，零代理流量。
# WEBSHARE_PROXY_USERNAME=
# WEBSHARE_PROXY_PASSWORD=
# 出口国家白名单（逗号分隔的 ISO-3166 二字码，留空 = 全球池）
# 离机器近的国家可降低延迟；HK/CN 服务器推荐 jp,tw,sg；美洲机器推荐 us,ca。
# 完整列表：https://www.webshare.io/features/proxy-locations
# WEBSHARE_FILTER_IP_LOCATIONS=jp,tw,us


# ============================================================
# 三、Worker 资源（start.sh 启动 2 个 celery 进程）
# ============================================================

# 主 worker：处理 youtube_fetching + youtube_transcription（短视频）。
#
# 默认 1：家用宽带上行普遍只有 10–50 Mbps，并发 2 个任务同时往 OSS 上传音频
# 会互相争抢带宽，触发 OSS ReadTimeout / 上传卡几分钟（日志里能看到
# 0.8 MB 文件传 5 分钟的极端情况）。串行反而更稳。
#
# 何时调高:
#   - 迁移到云 VPS（带宽 100 Mbps+） → 升到 2–4
#   - Upload Link 用户并发突增、Feed 任务被饿死 → 临时升到 2
WORKER_MAIN_CONCURRENCY=1

# 长视频 worker：专门处理 youtube_transcription_long，隔离大文件。
# 默认 1（也是推荐值）。家庭网络下千万别升到 2，单条长视频就能跑满整个上行。
WORKER_LONG_CONCURRENCY=1

# 单个 worker 子进程累计跑多少任务后自动重启（防内存泄漏）
WORKER_MAIN_MAX_TASKS_PER_CHILD=20
WORKER_LONG_MAX_TASKS_PER_CHILD=10

# celery worker 日志级别：debug / info / warning / error
WORKER_LOG_LEVEL=info


# ============================================================
# 四、Celery 任务超时（全局默认，长队列在代码里单独覆盖）
# ============================================================

# 短队列任务硬/软超时（秒），默认 2h/1h50m。短视频几乎不会触发，保底安全网。
TASK_TIME_LIMIT_SECONDS=7200
TASK_SOFT_TIME_LIMIT_SECONDS=6600

# Celery 结果保留时长（秒），用于前端轮询任务状态
RESULT_EXPIRES_SECONDS=3600


# ============================================================
# 五、长视频队列路由与超时
# ============================================================

# 超过此时长（秒）的视频会从 youtube_transcription 主队列
# 自动转发到 youtube_transcription_long 长视频专用队列。
# 默认 1800（30 分钟）。
ASR_LONG_VIDEO_THRESHOLD_SECONDS=1800

# 长视频任务的 Celery 硬/软超时（秒），覆盖上面的全局默认。
# Fun-ASR 允许 ≤12h 音频。默认硬 6h / 软 5.5h，足以覆盖 10h+ 直播回放。
ASR_LONG_TASK_TIME_LIMIT_SECONDS=21600
ASR_LONG_TASK_SOFT_TIME_LIMIT_SECONDS=19800


# ============================================================
# 六、失败重试策略
# ============================================================

# 瞬时错误（超时/429/网络/5xx）指数退避重试最大次数；
# 永久错误（视频不可用/私有/年龄限制/无人声/OSS 403）立即失败不重试。
# 退避公式: min(BASE * 2^n, MAX)s  →  120s → 240s → 480s → 600s ...
#
# 为什么降到 1：长视频若只是"本地轮询提前放弃"（并非 Fun-ASR 真失败），
# 每次重试都会重新下载 500MB+ 音频 + 重新上传 OSS + 重新提交 ASR，
# 非常浪费带宽和算力。把超时值调大（见 ASR_POLL_TIMEOUT_MINUTES_LONG）
# 让首次就跑完，比反复重试更划算。
ASR_MAX_RETRIES=1
ASR_RETRY_BACKOFF_BASE_SECONDS=120
ASR_RETRY_BACKOFF_MAX_SECONDS=600


# ============================================================
# 七、外部服务超时（网络条件差时可适度放大）
# ============================================================

# yt-dlp 下载行为
YTDLP_SOCKET_TIMEOUT_SECONDS=30
YTDLP_RETRIES=5
YTDLP_FRAGMENT_RETRIES=5

# TLS 指纹伪装（需要安装 curl-cffi：pip install "curl-cffi>=0.10,<0.15"）
# YouTube 字幕 CDN 对 Python urllib3 的 TLS 指纹会返回 429，用 curl-cffi
# 把请求伪装成真浏览器能大幅降低被限流概率。
#
# 注意 curl-cffi 版本上限！yt-dlp 的 bridge 只支持 0.5.10 / 0.10.x~0.14.x，
# 装了 0.15+ 会报 ImportError 导致 impersonation 不可用
#
# 推荐值 auto: yt-dlp 会自动从 curl-cffi 实际支持的 target 里挑一个，
# 避免指定具体名字（如 "chrome"）时因 curl-cffi 版本不支持而报错。
# 要查看本机实际支持的 target, 可在 worker 环境里运行:
#   python -c "import yt_dlp; y=yt_dlp.YoutubeDL({'quiet':True}); print(y._get_available_impersonate_targets())"
#
# 可选值:
#   auto / true / any  - 推荐，yt-dlp 自动挑选（即使 curl-cffi 版本变化也不会挂）
#   chrome / safari / edge / firefox - 指定 client（若不支持会自动降级为 auto）
#   chrome:windows / safari:ios-17   - 更具体，指定 client:os
#   false / off / 空    - 禁用 impersonation
YTDLP_IMPERSONATE=auto

# YouTube RSS / Data API v3 单次请求超时 + 失败重试
YOUTUBE_FEED_TIMEOUT_SECONDS=5
YOUTUBE_FEED_MAX_RETRIES=3

# youtube-transcript-api 单次拉取超时（IP 封锁时会挂死，所以要有硬超时）
# 注意：启用 Webshare 住宅代理后，住宅 IP 链路本身较慢，建议放宽到 45–60 秒。
YOUTUBE_TRANSCRIPT_TIMEOUT_SECONDS=30

# 字幕获取 fallback：transcript-api 失败后，用 yt-dlp 走 player endpoint 重试一次。
# 两条路径被 YouTube 独立限流，因此 transcript-api 被 IP 封禁时 yt-dlp 通常仍可用。
# 设为 false 禁用回退（字幕失败后直接派发 ASR）。
CAPTION_YTDLP_FALLBACK_ENABLED=true
# yt-dlp 拉字幕的总超时（含元信息获取 + 字幕文件下载）
CAPTION_YTDLP_TIMEOUT_SECONDS=60
# 每次字幕文件下载前睡眠秒数（yt-dlp 原生 --sleep-subtitles），降低被 YouTube
# 识别为爬虫的概率。0.5s 对吞吐几乎无影响但能显著降低触发限流的频次。
CAPTION_YTDLP_SLEEP_SUBTITLES_SECONDS=0.5
# 元信息提取期间每个请求间的睡眠秒数（yt-dlp 原生 --sleep-requests）
CAPTION_YTDLP_SLEEP_REQUESTS_SECONDS=0.5

# Fun-ASR 异步轮询最长等待时间（分钟）。
#
# ASR_POLL_TIMEOUT_MINUTES：短队列（youtube_transcription）使用的默认值。
#   适合 <30min 的音频，5min 足够；短视频快速失败有利于及时反馈问题。
#
# ASR_POLL_TIMEOUT_MINUTES_LONG：长队列（youtube_transcription_long）使用的值。
#   覆盖长视频场景。Fun-ASR 对 3h 音频典型耗时 10–25min（含排队），
#   默认 60min 对 ≤3h 视频有充足余量。若你常处理 6h+ 直播回放，可调到 120。
#   由 worker/tasks.py 的长队列分支显式传给 ASRService.transcribe()。
ASR_POLL_TIMEOUT_MINUTES=5
ASR_POLL_TIMEOUT_MINUTES_LONG=60


# ============================================================
# 八、日志
# ============================================================
LOG_DIR=./logs
LOG_LEVEL=INFO
